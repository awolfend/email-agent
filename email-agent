#!/bin/zsh

# ============================================================
# email-agent — start | stop | restart | debug | status
# ============================================================

PROJECT_DIR="$HOME/email-agent"
VENV_UVICORN="$PROJECT_DIR/venv/bin/uvicorn"
LOG_DIR="$PROJECT_DIR/logs"
PID_DIR="$PROJECT_DIR/logs"
OLLAMA_API="http://localhost:11434/api/tags"
SERVER_PORT="8000"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

ok()   { echo "${GREEN}  ✓ $1${NC}"; }
warn() { echo "${YELLOW}  ⚠ $1${NC}"; }
fail() { echo "${RED}  ✗ $1${NC}"; }
info() { echo "${BLUE}  → $1${NC}"; }
hdr()  { echo "${BOLD}$1${NC}"; }   # named hdr — avoids shadowing system head command

# ============================================================
# HELPERS
# ============================================================

get_tailscale_ip() { tailscale ip -4 2>/dev/null; }

ollama_running() { curl -sf "$OLLAMA_API" &>/dev/null; }

content_agent_running() { pgrep -f "uvicorn server:app" &>/dev/null; }

server_running() {
    [ -f "$PID_DIR/server.pid" ] && kill -0 "$(cat $PID_DIR/server.pid)" 2>/dev/null
}

server_responding() {
    local ip="$1"
    curl -sf "http://$ip:$SERVER_PORT/" &>/dev/null
}

purge_old_logs() { find "$LOG_DIR" -name "*.log" -mtime +14 -delete 2>/dev/null; }

# ============================================================
# START
# ============================================================

cmd_start() {
    echo ""
    hdr "⚡ Email Agent — Starting"
    echo "=========================="

    mkdir -p "$LOG_DIR"
    purge_old_logs

    # --- Tailscale ---
    echo ""
    hdr "1. Tailscale"
    if tailscale status &>/dev/null; then
        ok "Connected — IP: $(get_tailscale_ip)"
    else
        info "Not connected — attempting tailscale up..."
        tailscale up 2>/dev/null
        for i in {1..5}; do
            if tailscale status &>/dev/null; then
                echo "yes" > "$PID_DIR/email-tailscale-started-by-us"
                ok "Connected — IP: $(get_tailscale_ip)"
                break
            fi
            if [ $i -eq 5 ]; then
                fail "Tailscale did not connect — run: tailscale up"
                exit 1
            fi
            sleep 1
        done
    fi
    local ts_ip=$(get_tailscale_ip)

    # --- Ollama ---
    echo ""
    hdr "2. Ollama"

    if ollama_running; then
        ok "Already running"
        rm -f "$PID_DIR/email-ollama-started-by-us"
    else
        info "Starting Ollama..."
        ollama serve >> "$LOG_DIR/ollama.log" 2>&1 &
        local ollama_pid=$!
        disown $ollama_pid
        echo $ollama_pid > "$PID_DIR/email-ollama.pid"
        echo "yes" > "$PID_DIR/email-ollama-started-by-us"

        for i in {1..10}; do
            if ollama_running; then
                ok "Started (PID $ollama_pid)"
                break
            fi
            if [ $i -eq 10 ]; then
                fail "Ollama did not start within 10 seconds — check $LOG_DIR/ollama.log"
                exit 1
            fi
            sleep 1
        done
    fi

    if curl -sf "$OLLAMA_API" | grep -q "phi4-mini"; then
        ok "phi4-mini:latest available"
    else
        warn "phi4-mini:latest not found — run: ollama pull phi4-mini:latest"
    fi

    # --- Server ---
    echo ""
    hdr "3. Email Agent Server"

    if server_running; then
        local pid=$(cat "$PID_DIR/server.pid")
        warn "Already running (PID $pid) — use 'email-agent restart' to restart"
        echo ""
        echo "=========================="
        ok "Email Agent already running — http://$ts_ip:$SERVER_PORT"
        echo "=========================="
        echo ""
        return 0
    fi

    cd "$PROJECT_DIR"
    info "Starting server..."
    nohup $VENV_UVICORN main:app \
        --host "$ts_ip" \
        --port "$SERVER_PORT" \
        >> "$LOG_DIR/server.log" 2>&1 &

    local server_pid=$!
    disown $server_pid
    echo $server_pid > "$PID_DIR/server.pid"

    info "Waiting for server to respond..."
    for i in {1..8}; do
        if server_responding "$ts_ip"; then
            ok "Started (PID $server_pid)"
            break
        fi
        if ! kill -0 "$server_pid" 2>/dev/null; then
            fail "Server process died — check $LOG_DIR/server.log"
            rm -f "$PID_DIR/server.pid"
            exit 1
        fi
        if [ $i -eq 8 ]; then
            warn "Server started but not yet responding — check $LOG_DIR/server.log"
        fi
        sleep 1
    done

    # Auth proxy — nohup+disown ensures it survives this script exiting
    pkill -f "auth_proxy.py" 2>/dev/null; sleep 0.5
    nohup "$PROJECT_DIR/venv/bin/python3" "$PROJECT_DIR/auth_proxy.py" \
        >> "$LOG_DIR/server.log" 2>&1 &
    local proxy_pid=$!
    disown $proxy_pid
    echo $proxy_pid > "$PID_DIR/auth_proxy.pid"
    sleep 1
    if kill -0 $proxy_pid 2>/dev/null; then
        ok "Auth proxy started (localhost:8000 → $ts_ip:$SERVER_PORT, PID $proxy_pid)"
    else
        warn "Auth proxy failed to start — check $LOG_DIR/server.log"
    fi

    echo ""
    echo "=========================="
    ok "Email Agent is running"
    echo "   Dashboard: http://$ts_ip:$SERVER_PORT"
    echo "   Logs:      $LOG_DIR/"
    echo "   Stop:      email-agent stop"
    echo "=========================="
    echo ""
}

# ============================================================
# STOP
# ============================================================

cmd_stop() {
    echo ""
    hdr "⚡ Email Agent — Stopping"
    echo "=========================="

    # --- Server ---
    echo ""
    hdr "1. Server + Auth Proxy"
    local running_pid=$(pgrep -f "uvicorn main:app" 2>/dev/null | command head -n1)
    if [ -n "$running_pid" ]; then
        kill "$running_pid" 2>/dev/null
        for i in {1..5}; do
            if ! kill -0 "$running_pid" 2>/dev/null; then
                ok "Server stopped (PID $running_pid)"
                break
            fi
            if [ $i -eq 5 ]; then
                kill -9 "$running_pid" 2>/dev/null
                ok "Server force-stopped (PID $running_pid)"
            fi
            sleep 1
        done
    else
        warn "Server not running"
    fi
    rm -f "$PID_DIR/server.pid"

    local proxy_pid=$(pgrep -f "auth_proxy.py" 2>/dev/null | command head -n1)
    if [ -n "$proxy_pid" ]; then
        kill "$proxy_pid" 2>/dev/null
        ok "Auth proxy stopped (PID $proxy_pid)"
    fi
    rm -f "$PID_DIR/auth_proxy.pid"

    # --- Ollama ---
    echo ""
    hdr "2. Ollama"
    if [ -f "$PID_DIR/email-ollama-started-by-us" ]; then
        if content_agent_running; then
            ok "Left running — content-agent is still using it"
        else
            local ollama_pid=$(pgrep -f "ollama" 2>/dev/null | command head -n1)
            if [ -n "$ollama_pid" ]; then
                kill "$ollama_pid" 2>/dev/null
                for i in {1..5}; do
                    if ! kill -0 "$ollama_pid" 2>/dev/null; then
                        ok "Stopped (PID $ollama_pid)"
                        break
                    fi
                    if [ $i -eq 5 ]; then
                        kill -9 "$ollama_pid" 2>/dev/null
                        ok "Force stopped (PID $ollama_pid)"
                    fi
                    sleep 1
                done
            else
                warn "Ollama not running (already stopped)"
            fi
            rm -f "$PID_DIR/email-ollama.pid"
        fi
        rm -f "$PID_DIR/email-ollama-started-by-us"
    else
        ok "Left running (not started by email-agent)"
    fi

    # --- Tailscale ---
    echo ""
    hdr "3. Tailscale"
    if [ -f "$PID_DIR/email-tailscale-started-by-us" ]; then
        if content_agent_running; then
            ok "Left connected — content-agent is still using it"
        else
            tailscale down 2>/dev/null && ok "Disconnected" || warn "Could not disconnect Tailscale"
        fi
        rm -f "$PID_DIR/email-tailscale-started-by-us"
    else
        ok "Left connected (was already up before email-agent started)"
    fi

    echo ""
    echo "=========================="
    ok "Email Agent stopped"
    echo "=========================="
    echo ""
}

# ============================================================
# STATUS
# ============================================================

cmd_status() {
    echo ""
    hdr "⚡ Email Agent — Status"
    echo "=========================="

    echo ""
    hdr "Tailscale"
    if tailscale status &>/dev/null; then
        ok "Connected — IP: $(get_tailscale_ip)"
    else
        fail "Not connected — run: tailscale up"
    fi

    echo ""
    hdr "Ollama"
    if ollama_running; then
        ok "Running"
        if curl -sf "$OLLAMA_API" | grep -q "phi4-mini"; then
            ok "phi4-mini:latest loaded"
        else
            warn "phi4-mini:latest not found"
        fi
    else
        fail "Not running"
    fi

    echo ""
    hdr "Email Agent Server"
    local running_pid=$(pgrep -f "uvicorn main:app" 2>/dev/null | command head -n1)
    if [ -n "$running_pid" ]; then
        ok "Running (PID $running_pid)"
        local ip=$(get_tailscale_ip)
        if [ -n "$ip" ] && server_responding "$ip"; then
            ok "Responding at http://$ip:$SERVER_PORT"
        elif server_responding "127.0.0.1"; then
            ok "Responding at http://127.0.0.1:$SERVER_PORT"
        else
            warn "Process running but not responding to HTTP"
        fi
    else
        fail "Not running"
    fi

    echo ""
    hdr "Auth Proxy"
    local proxy_pid=$(pgrep -f "auth_proxy.py" 2>/dev/null | command head -n1)
    if [ -n "$proxy_pid" ]; then
        ok "Running (PID $proxy_pid)"
    else
        warn "Not running"
    fi

    echo ""
    hdr "Content Agent"
    if content_agent_running; then
        ok "Running (shared Ollama/Tailscale)"
    else
        info "Not running"
    fi

    echo ""
    hdr "Recent log"
    if [ -f "$LOG_DIR/server.log" ]; then
        tail -5 "$LOG_DIR/server.log" | sed 's/^/     /'
    else
        info "No log yet"
    fi

    echo ""
    echo "=========================="
    echo ""
}

# ============================================================
# RESTART
# ============================================================

cmd_restart() {
    echo ""
    hdr "⚡ Email Agent — Restarting"
    cmd_stop
    sleep 1
    cmd_start
}

# ============================================================
# DEBUG
# ============================================================

cmd_debug() {
    echo ""
    hdr "⚡ Email Agent — Debug mode (foreground)"
    echo "   Ctrl+C to stop"
    echo ""

    mkdir -p "$LOG_DIR"

    if ! tailscale status &>/dev/null; then
        info "Tailscale not connected — attempting tailscale up..."
        tailscale up 2>/dev/null
        sleep 2
        if ! tailscale status &>/dev/null; then
            fail "Tailscale not connected — run: tailscale up"
            exit 1
        fi
    fi
    local ts_ip=$(get_tailscale_ip)
    ok "Tailscale: $ts_ip"

    if ollama_running; then
        ok "Ollama: running"
    else
        warn "Ollama not running — starting..."
        ollama serve >> "$LOG_DIR/ollama.log" 2>&1 &
        disown $!
        sleep 3
        if ollama_running; then
            ok "Ollama: started"
        else
            fail "Ollama failed to start — check $LOG_DIR/ollama.log"
            exit 1
        fi
    fi

    echo ""
    info "Starting server in foreground with --reload..."
    echo ""

    cd "$PROJECT_DIR"
    $VENV_UVICORN main:app \
        --host "$ts_ip" \
        --port "$SERVER_PORT" \
        --reload
}

# ============================================================
# ENTRY POINT
# ============================================================

case "$1" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    debug)   cmd_debug ;;
    status)  cmd_status ;;
    *)
        echo ""
        echo "Usage: email-agent <command>"
        echo ""
        echo "Commands:"
        echo "  start    Start all services in background"
        echo "  stop     Stop all services"
        echo "  restart  Stop then start"
        echo "  debug    Start in foreground with live logs and --reload"
        echo "  status   Show status of all services"
        echo ""
        exit 1
        ;;
esac
