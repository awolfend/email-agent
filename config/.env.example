# Copy this file to config/.env and fill in real values.
# config/.env is gitignored — never commit it.

# Network
TAILSCALE_IP=                        # Output of: tailscale ip -4

# Account email addresses
FINANCIAL_EMAIL=                     # M365 financial planning account email
GMAIL_EMAIL=                         # Gmail / tax account email
PERSONAL_EMAIL=                      # M365 personal account email
FILING_EMAIL_FINANCIAL=              # CC address for financial replies (e.g. a filing/archiving inbox)

# Business identity — used in default draft prompts
FINANCIAL_BUSINESS_NAME=
TAX_BUSINESS_NAME=
AR_NUMBER=                           # Authorised Representative number
TAX_TRN_NUMBER=                      # Registered Tax Agent number

# AI provider routing
DRAFT_DEFAULT_PROVIDER=claude
COMPLEX_ANALYSIS_DEFAULT_PROVIDER=claude
FALLBACK_PROVIDER=gemini

# M365 financial planning app registration
AZURE_CLIENT_ID_FINANCIAL=
AZURE_CLIENT_SECRET_FINANCIAL=
AZURE_TENANT_ID=
AZURE_OBJECT_ID_FINANCIAL=

# M365 personal app registration
AZURE_CLIENT_ID_PERSONAL=
AZURE_CLIENT_SECRET_PERSONAL=
AZURE_OBJECT_ID_PERSONAL=

# Gmail OAuth app registration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# LinkedIn OAuth (if used)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook app (if used)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=

# HubSpot CRM — Personal Access Token
# Required scopes: crm.objects.contacts.read, crm.objects.notes.read,
#   crm.objects.meetings.read, crm.objects.emails.read,
#   crm.objects.calls.read, crm.objects.tasks.read, crm.objects.deals.read
HUBSPOT_API_KEY=
